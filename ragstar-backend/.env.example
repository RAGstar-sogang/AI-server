# Copy this file to `.env` and fill in the values for your environment:
#   cp .env.example .env
#
# `.env` itself is gitignored and must NEVER be committed (it holds real secrets).
# Only this example, with placeholder values, belongs in the repo.

# ── vLLM OpenAI-compatible server for all generation/chat LLM calls ──
VLLM_BASE_URL=http://127.0.0.1:8000/v1
VLLM_API_KEY=EMPTY
VLLM_DEFAULT_CHAT_MODEL=qwen3.5-9b
VLLM_NODE2_MODEL=
VLLM_NODE4_MODEL=
VLLM_EXP2_BASE_MODEL=
VLLM_TEMPERATURE=0
VLLM_TIMEOUT=120
VLLM_MAX_RETRIES=2
VLLM_JSON_MODE=true
VLLM_AUTO_SWITCH_MODEL=true
VLLM_MANAGE_SCRIPT=/workspace/vllm/manage.sh
VLLM_SERVE_ENV=/workspace/vllm/serve.env
VLLM_MODEL_PROFILES=/workspace/vllm/model_profiles.json
VLLM_MODELS_ROOT=/workspace/vllm/models
VLLM_SWITCH_TIMEOUT_SECONDS=240

# ── Ollama is kept only for nomic-embed-text embeddings to preserve Chroma compatibility. ──
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
CHROMA_COLLECTION_NAME=oom_kb

# ── Web server that receives diagnosis results ──
# Set this to your own host. Do NOT commit a real internal/public IP.
WEB_SERVER_URL=http://YOUR_WEB_SERVER_HOST:8000
#WEB_SERVER_URL=http://127.0.0.1:8001

# ── OpenAI (GPT baseline / comparison only) ──
# Put your real key in `.env`, never here. Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-REPLACE_WITH_YOUR_OWN_KEY
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.2
