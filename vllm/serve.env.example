# Copy this file to serve.env and edit values for the model you want to run.
#
# manage.sh loads serve.env automatically before it starts start.sh:
#   ./manage.sh restart

MODEL_PROFILE=qwen3.5-9b
MODEL_DIR=/workspace/vllm/models/Qwen/Qwen3.5-9B
SERVED_MODEL_NAME=qwen3.5-9b

HOST=0.0.0.0
PORT=8000

CUDA_VISIBLE_DEVICES=0,1
TENSOR_PARALLEL_SIZE=2

MAX_MODEL_LEN=4096
MAX_NUM_BATCHED_TOKENS=4096
MAX_NUM_SEQS=32
GPU_MEMORY_UTILIZATION=0.90
MAX_CUDAGRAPH_CAPTURE_SIZE=1024
DTYPE=auto

# 1 starts faster and avoids compile/cudagraph startup pressure.
# 0 can improve sustained throughput after warmup, but uses compile/cudagraph.
ENFORCE_EAGER=1
